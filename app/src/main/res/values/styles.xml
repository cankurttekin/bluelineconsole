<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Basic definition for light and dark -->

    <style name="BaseAppThemeLight" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="android:colorBackground">@color/baseBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="andmenuAccentColor">@color/colorAccent</item>
        <item name="andmenuBaseTextColor">@color/baseText</item>
        <item name="andmenuDisabledTextColor">@color/disabledText</item>
        <item name="andmenuSelectedItemBackgroundColor">@color/selectedItemBackground</item>
        <item name="andmenuBackgroundColorOfCommand">@color/colorBackgroundOfCommand</item>
    </style>

    <style name="BaseAppThemeDark" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="android:colorBackground">@color/baseBackgroundDark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="andmenuAccentColor">@color/colorAccentDark</item>
        <item name="andmenuBaseTextColor">@color/baseTextDark</item>
        <item name="andmenuDisabledTextColor">@color/disabledTextDark</item>
        <item name="andmenuSelectedItemBackgroundColor">@color/selectedItemBackgroundDark</item>
        <item name="andmenuBackgroundColorOfCommand">@color/colorBackgroundOfCommandDark</item>
    </style>
</resources>
