        <item name="bluelineconsoleFrameColor">@color/rosepine_command_bg</item>
        <item name="bluelineconsoleFrameTextColor">@color/rosepine_fg</item>
        <item name="bluelineconsoleSelectedItemBackgroundColor">@color/rosepine_selected</item>
        <item name="bluelineconsoleBackgroundColorOfCommand">@color/rosepine_command_bg</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="AppThemeRosePineHome" parent="AppThemeRosePine">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowShowWallpaper">true</item>
    </style>

    <!-- dmenu -->
    <style name="AppThemeDmenu" parent="Theme.AppCompat.NoActionBar">
        <item name="android:colorBackground">@color/dmenu_bg</item>
        <item name="android:textColor">@color/dmenu_fg</item>
        <item name="bluelineconsoleAccentColor">@color/dmenu_accent</item>
        <item name="bluelineconsoleBaseTextColor">@color/dmenu_fg</item>
        <item name="bluelineconsoleFrameColor">@color/dmenu_bg</item>
        <item name="bluelineconsoleFrameTextColor">@color/dmenu_fg</item>
        <item name="bluelineconsoleSelectedItemBackgroundColor">@color/dmenu_selected</item>
        <item name="bluelineconsoleBackgroundColorOfCommand">@color/dmenu_bg</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="AppThemeDmenuHome" parent="AppThemeDmenu">
        <item name="android:windowIsTranslucent">false</item>
