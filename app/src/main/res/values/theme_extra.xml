<resources>
    <!-- Gruvbox -->
    <style name="AppThemeGruvbox" parent="Theme.AppCompat.NoActionBar">
        <item name="android:colorBackground">@color/gruvbox_bg</item>
        <item name="android:textColor">@color/gruvbox_fg</item>
        <item name="bluelineconsoleAccentColor">@color/gruvbox_accent</item>
        <item name="bluelineconsoleBaseTextColor">@color/gruvbox_fg</item>
        <item name="bluelineconsoleFrameColor">@color/gruvbox_command_bg</item>
        <item name="bluelineconsoleFrameTextColor">@color/gruvbox_fg</item>
        <item name="bluelineconsoleSelectedItemBackgroundColor">@color/gruvbox_selected</item>
        <item name="bluelineconsoleBackgroundColorOfCommand">@color/gruvbox_command_bg</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="AppThemeGruvboxHome" parent="AppThemeGruvbox">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowShowWallpaper">true</item>
    </style>

    <!-- Rose Pine -->
